# ── Copy this to .env and fill in every value ────────────
# NEVER commit .env to git

# PostgreSQL
POSTGRES_DB=apexverse
POSTGRES_USER=apexverse
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# JWT  (generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_64_char_hex
JWT_REFRESH_SECRET=CHANGE_ME_64_char_hex_different

# Encryption key for storing vector DB credentials (openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_32_char_hex

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=https://api.apexverse.ai/auth/google/callback

# Stripe (dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...

# Email — SendGrid (sendgrid.com)
SENDGRID_API_KEY=SG....
FROM_EMAIL=billing@apexverse.ai
FROM_NAME=Apexverse

# AWS S3 (for invoice storage — optional initially)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=apexverse-files
AWS_REGION=us-east-1

# Scraper service
SCRAPER_SERVICE_URL=http://scraper:8060
SCRAPER_WEBHOOK_SECRET=CHANGE_ME_scraper_secret

# URLs
FRONTEND_URL=https://apexverse.ai
BACKEND_URL=https://api.apexverse.ai
NEXT_PUBLIC_API_URL=https://api.apexverse.ai

# App
DEBUG=false
